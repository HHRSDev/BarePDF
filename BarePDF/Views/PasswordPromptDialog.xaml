<ui:FluentWindow x:Class="BarePDF.Views.PasswordPromptDialog"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="BarePDF"
                 Icon="/Resources/BarePDF.ico"
                 Width="440" SizeToContent="Height"
                 WindowStartupLocation="CenterOwner"
                 ResizeMode="NoResize"
                 ShowInTaskbar="False"
                 WindowBackdropType="Mica"
                 ExtendsContentIntoTitleBar="True"
                 WindowCornerPreference="Round">
    <DockPanel>
        <ui:TitleBar DockPanel.Dock="Top"
                     Title="{Binding Title, RelativeSource={RelativeSource AncestorType=Window}}">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="/Resources/BarePDF.ico"/>
            </ui:TitleBar.Icon>
        </ui:TitleBar>
        <StackPanel Margin="24,8,24,24">
            <TextBlock x:Name="Heading"
                       FontSize="16" FontWeight="SemiBold"
                       Margin="0,0,0,4"/>
            <TextBlock x:Name="Subheading"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       TextWrapping="Wrap"
                       Margin="0,0,0,12"/>
            <PasswordBox x:Name="PasswordInput"
                         Margin="0,0,0,16"
                         KeyDown="OnPasswordKeyDown"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <ui:Button Content="OK" Width="88" Margin="0,0,8,0"
                           Appearance="Primary" IsDefault="True"
                           Click="OnOkClick"/>
                <ui:Button Content="Cancel" Width="88" IsCancel="True"/>
            </StackPanel>
        </StackPanel>
    </DockPanel>
</ui:FluentWindow>
