<UserControl x:Class="BarePDF.Views.FindBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <Border Background="{DynamicResource ControlSolidFillColorDefaultBrush}"
            BorderBrush="{DynamicResource ControlElevationBorderBrush}"
            BorderThickness="0,0,0,1"
            Padding="8,6">
        <StackPanel Orientation="Horizontal">
            <ui:TextBox x:Name="QueryBox"
                        Width="280"
                        PlaceholderText="Find in document"
                        TextChanged="OnQueryTextChanged"
                        PreviewKeyDown="OnQueryKeyDown"/>
            <TextBlock x:Name="CountLabel"
                       VerticalAlignment="Center"
                       Margin="8,0,0,0"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
            <CheckBox x:Name="CaseSensitiveCheck"
                      Content="Aa"
                      ToolTip="Match case"
                      VerticalAlignment="Center"
                      Margin="8,0,0,0"
                      Click="OnOptionsChanged"/>
            <CheckBox x:Name="WholeWordCheck"
                      Content="W"
                      ToolTip="Whole words only"
                      VerticalAlignment="Center"
                      Margin="4,0,0,0"
                      Click="OnOptionsChanged"/>
            <ui:Button Content="↑" Width="32" Margin="8,0,0,0" Click="OnPrevClick" ToolTip="Previous (Shift+Enter)"/>
            <ui:Button Content="↓" Width="32" Margin="2,0,0,0" Click="OnNextClick" ToolTip="Next (Enter)"/>
            <ui:Button Content="✕" Width="32" Margin="8,0,0,0" Click="OnCloseClick" ToolTip="Close (Esc)"/>
        </StackPanel>
    </Border>
</UserControl>
