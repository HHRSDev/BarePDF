<UserControl x:Class="BarePDF.Views.ThumbnailStrip"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="180"
             Background="{DynamicResource ControlSolidFillColorDefaultBrush}">
    <ListBox x:Name="ThumbList"
             BorderThickness="0"
             Background="Transparent"
             Padding="8"
             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
             ScrollViewer.VerticalScrollBarVisibility="Auto"
             ScrollViewer.CanContentScroll="True"
             VirtualizingPanel.IsVirtualizing="True"
             VirtualizingPanel.VirtualizationMode="Recycling"
             VirtualizingPanel.ScrollUnit="Pixel"
             KeyboardNavigation.DirectionalNavigation="None"
             SelectionChanged="OnThumbnailSelected">
        <ListBox.ItemsPanel>
            <ItemsPanelTemplate>
                <VirtualizingStackPanel Orientation="Vertical"/>
            </ItemsPanelTemplate>
        </ListBox.ItemsPanel>
        <ListBox.ItemContainerStyle>
            <Style TargetType="ListBoxItem">
                <Setter Property="Margin" Value="0,0,0,12"/>
                <Setter Property="HorizontalAlignment" Value="Center"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="Focusable" Value="False"/>
                <Setter Property="IsTabStop" Value="False"/>
                <Setter Property="Cursor" Value="Hand"/>
            </Style>
        </ListBox.ItemContainerStyle>
        <ListBox.ItemTemplate>
            <DataTemplate>
                <StackPanel HorizontalAlignment="Center">
                    <Border Background="White"
                            BorderBrush="#444"
                            BorderThickness="1"
                            SnapsToDevicePixels="True"
                            Width="148"
                            DataContextChanged="OnThumbnailContainerDataContextChanged">
                        <Image Source="{Binding Thumbnail}" Stretch="Uniform"/>
                    </Border>
                    <TextBlock Text="{Binding PageNumber}"
                               HorizontalAlignment="Center"
                               Margin="0,4,0,0"
                               FontSize="11"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                </StackPanel>
            </DataTemplate>
        </ListBox.ItemTemplate>
    </ListBox>
</UserControl>
