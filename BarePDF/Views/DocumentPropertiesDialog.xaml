<ui:FluentWindow x:Class="BarePDF.Views.DocumentPropertiesDialog"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="Document Properties"
                 Icon="/Resources/BarePDF.ico"
                 Width="520" SizeToContent="Height"
                 WindowStartupLocation="CenterOwner"
                 ResizeMode="NoResize"
                 ShowInTaskbar="False"
                 WindowBackdropType="Mica"
                 ExtendsContentIntoTitleBar="True"
                 WindowCornerPreference="Round">
    <DockPanel>
        <ui:TitleBar DockPanel.Dock="Top"
                     Title="{Binding Title, RelativeSource={RelativeSource AncestorType=Window}}">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="/Resources/BarePDF.ico"/>
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <StackPanel Margin="24,8,24,24">
            <TextBlock Text="Document" FontWeight="SemiBold" Margin="0,0,0,8"/>
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="File:"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                <TextBlock x:Name="FileNameText" Grid.Row="0" Grid.Column="1"
                           TextTrimming="CharacterEllipsis" Margin="0,0,0,4"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Folder:"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                <TextBlock x:Name="FolderText" Grid.Row="1" Grid.Column="1"
                           TextTrimming="CharacterEllipsis" Margin="0,0,0,4"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Pages:"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                <TextBlock x:Name="PageCountText" Grid.Row="2" Grid.Column="1" Margin="0,0,0,4"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="File size:"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                <TextBlock x:Name="FileSizeText" Grid.Row="3" Grid.Column="1" Margin="0,0,0,4"/>
            </Grid>

            <TextBlock Text="Metadata" FontWeight="SemiBold" Margin="0,0,0,8"/>
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Title:"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                <TextBlock x:Name="TitleText" Grid.Row="0" Grid.Column="1"
                           TextWrapping="Wrap" Margin="0,0,0,4"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Author:"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                <TextBlock x:Name="AuthorText" Grid.Row="1" Grid.Column="1"
                           TextWrapping="Wrap" Margin="0,0,0,4"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Subject:"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                <TextBlock x:Name="SubjectText" Grid.Row="2" Grid.Column="1"
                           TextWrapping="Wrap" Margin="0,0,0,4"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Keywords:"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                <TextBlock x:Name="KeywordsText" Grid.Row="3" Grid.Column="1"
                           TextWrapping="Wrap" Margin="0,0,0,4"/>

                <TextBlock Grid.Row="4" Grid.Column="0" Text="Creator:"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                <TextBlock x:Name="CreatorText" Grid.Row="4" Grid.Column="1"
                           TextWrapping="Wrap" Margin="0,0,0,4"/>

                <TextBlock Grid.Row="5" Grid.Column="0" Text="Producer:"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                <TextBlock x:Name="ProducerText" Grid.Row="5" Grid.Column="1"
                           TextWrapping="Wrap" Margin="0,0,0,4"/>

                <TextBlock Grid.Row="6" Grid.Column="0" Text="Created:"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                <TextBlock x:Name="CreatedText" Grid.Row="6" Grid.Column="1" Margin="0,0,0,4"/>

                <TextBlock Grid.Row="7" Grid.Column="0" Text="Modified:"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                <TextBlock x:Name="ModifiedText" Grid.Row="7" Grid.Column="1" Margin="0,0,0,4"/>

                <TextBlock Grid.Row="8" Grid.Column="0" Text="PDF version:"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                <TextBlock x:Name="PdfVersionText" Grid.Row="8" Grid.Column="1" Margin="0,0,0,4"/>
            </Grid>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <ui:Button Content="OK" Width="88" IsDefault="True" IsCancel="True"
                           Appearance="Primary" Click="OnOkClick"/>
            </StackPanel>
        </StackPanel>
    </DockPanel>
</ui:FluentWindow>
