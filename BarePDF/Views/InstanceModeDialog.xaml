<ui:FluentWindow x:Class="BarePDF.Views.InstanceModeDialog"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="BarePDF"
                 Icon="/Resources/BarePDF.ico"
                 Width="520" SizeToContent="Height"
                 WindowStartupLocation="CenterOwner"
                 ResizeMode="NoResize"
                 ShowInTaskbar="False"
                 WindowBackdropType="Mica"
                 ExtendsContentIntoTitleBar="True"
                 WindowCornerPreference="Round">
    <DockPanel>
        <ui:TitleBar DockPanel.Dock="Top" Title="BarePDF">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="/Resources/BarePDF.ico"/>
            </ui:TitleBar.Icon>
        </ui:TitleBar>
        <StackPanel Margin="24,8,24,24">
            <TextBlock x:Name="Heading"
                       FontSize="18" FontWeight="SemiBold"
                       Margin="0,0,0,4"/>
            <TextBlock Text="How would you like BarePDF to handle opening multiple PDFs?"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       TextWrapping="Wrap"
                       Margin="0,0,0,16"/>

            <RadioButton x:Name="SingletonOption" GroupName="Mode" Margin="0,0,0,12" Padding="6,0,0,0">
                <StackPanel>
                    <TextBlock Text="Single window" FontWeight="SemiBold"/>
                    <TextBlock Text="One window only. Opening another PDF replaces the current one."
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </RadioButton>

            <RadioButton x:Name="MultipleOption" GroupName="Mode" Margin="0,0,0,12" Padding="6,0,0,0">
                <StackPanel>
                    <TextBlock Text="Multiple windows" FontWeight="SemiBold"/>
                    <TextBlock Text="Each PDF opens in its own window."
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </RadioButton>

            <RadioButton x:Name="TabbedOption" GroupName="Mode" Margin="0,0,0,20" Padding="6,0,0,0">
                <StackPanel>
                    <TextBlock Text="Tabbed" FontWeight="SemiBold"/>
                    <TextBlock Text="A single window holds all open PDFs as tabs."
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </RadioButton>

            <StackPanel x:Name="AppearanceSection" Margin="0,4,0,16">
                <TextBlock Text="Appearance" FontWeight="SemiBold" Margin="0,0,0,6"/>
                <ComboBox x:Name="ThemeCombo"
                          Width="260"
                          HorizontalAlignment="Left">
                    <ComboBoxItem Tag="System">Follow Windows</ComboBoxItem>
                    <ComboBoxItem Tag="Light">Light</ComboBoxItem>
                    <ComboBoxItem Tag="Dark">Dark</ComboBoxItem>
                </ComboBox>
            </StackPanel>

            <StackPanel x:Name="WindowSection" Margin="0,0,0,20">
                <TextBlock Text="Window" FontWeight="SemiBold" Margin="0,0,0,6"/>
                <CheckBox x:Name="AutoFitWidthCheckbox"
                          Content="Resize window width to fit document on open"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <ui:Button x:Name="OkButton" Content="OK" Width="88" Margin="0,0,8,0"
                           Appearance="Primary"
                           IsDefault="True" Click="OnOkClick"/>
                <ui:Button Content="Cancel" Width="88" IsCancel="True"/>
            </StackPanel>
        </StackPanel>
    </DockPanel>
</ui:FluentWindow>
