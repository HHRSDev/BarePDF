<Window x:Class="BarePDF.Views.InstanceModeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BarePDF"
        Width="500" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <StackPanel Margin="20">
        <TextBlock x:Name="Heading"
                   FontSize="16" FontWeight="SemiBold"
                   Margin="0,0,0,4"/>
        <TextBlock Text="How would you like BarePDF to handle opening multiple PDFs?"
                   TextWrapping="Wrap"
                   Margin="0,0,0,16"/>

        <RadioButton x:Name="SingletonOption" GroupName="Mode" Margin="0,0,0,12" Padding="6,0,0,0">
            <StackPanel>
                <TextBlock Text="Single window" FontWeight="SemiBold"/>
                <TextBlock Text="One window only. Opening another PDF replaces the current one."
                           Foreground="#666" TextWrapping="Wrap"/>
            </StackPanel>
        </RadioButton>

        <RadioButton x:Name="MultipleOption" GroupName="Mode" Margin="0,0,0,12" Padding="6,0,0,0">
            <StackPanel>
                <TextBlock Text="Multiple windows" FontWeight="SemiBold"/>
                <TextBlock Text="Each PDF opens in its own window."
                           Foreground="#666" TextWrapping="Wrap"/>
            </StackPanel>
        </RadioButton>

        <RadioButton x:Name="TabbedOption" GroupName="Mode" Margin="0,0,0,16" Padding="6,0,0,0">
            <StackPanel>
                <TextBlock Text="Tabbed" FontWeight="SemiBold"/>
                <TextBlock Text="A single window holds all open PDFs as tabs."
                           Foreground="#666" TextWrapping="Wrap"/>
            </StackPanel>
        </RadioButton>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="OkButton" Content="OK" Width="80" Margin="0,0,8,0"
                    IsDefault="True" Click="OnOkClick"/>
            <Button Content="Cancel" Width="80" IsCancel="True"/>
        </StackPanel>
    </StackPanel>
</Window>
