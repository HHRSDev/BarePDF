<ui:FluentWindow x:Class="BarePDF.Views.GoToPageDialog"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="Go to Page"
                 Icon="/Resources/BarePDF.ico"
                 Width="380" SizeToContent="Height"
                 WindowStartupLocation="CenterOwner"
                 ResizeMode="NoResize"
                 ShowInTaskbar="False"
                 WindowBackdropType="Mica"
                 ExtendsContentIntoTitleBar="True"
                 WindowCornerPreference="Round">
    <DockPanel>
        <ui:TitleBar DockPanel.Dock="Top" Title="BarePDF">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="/Resources/BarePDF.ico"/>
            </ui:TitleBar.Icon>
        </ui:TitleBar>
        <StackPanel Margin="24,8,24,24">
            <TextBlock x:Name="Prompt"
                       Margin="0,0,0,10"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
            <ui:TextBox x:Name="PageInput"
                        Width="120"
                        HorizontalAlignment="Left"
                        Margin="0,0,0,16"
                        PreviewKeyDown="OnPageInputKeyDown"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <ui:Button Content="OK" Width="88" Margin="0,0,8,0"
                           Appearance="Primary" IsDefault="True"
                           Click="OnOkClick"/>
                <ui:Button Content="Cancel" Width="88" IsCancel="True"/>
            </StackPanel>
        </StackPanel>
    </DockPanel>
</ui:FluentWindow>
