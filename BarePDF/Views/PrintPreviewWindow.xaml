<ui:FluentWindow x:Class="BarePDF.Views.PrintPreviewWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="Print Preview"
                 Icon="/Resources/BarePDF.ico"
                 Width="900" Height="720"
                 WindowStartupLocation="CenterOwner"
                 WindowBackdropType="Mica"
                 ExtendsContentIntoTitleBar="True"
                 WindowCornerPreference="Round">
    <DockPanel>
        <ui:TitleBar DockPanel.Dock="Top"
                     Title="{Binding Title, RelativeSource={RelativeSource AncestorType=Window}}">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="/Resources/BarePDF.ico"/>
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <Border DockPanel.Dock="Top"
                BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                Padding="12,8">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <ui:Button Width="32" Height="28" Margin="0,0,4,0" Padding="0"
                               Appearance="Transparent" ToolTip="Previous page"
                               Click="OnPrevPageClick">
                        <TextBlock Text="◀" FontSize="11"/>
                    </ui:Button>
                    <ui:Button Width="32" Height="28" Margin="0,0,12,0" Padding="0"
                               Appearance="Transparent" ToolTip="Next page"
                               Click="OnNextPageClick">
                        <TextBlock Text="▶" FontSize="11"/>
                    </ui:Button>
                    <TextBlock x:Name="PageIndicator" Text="0 / 0"
                               VerticalAlignment="Center"
                               FontSize="13"
                               Margin="0,0,16,0"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                    <ui:Button Width="32" Height="28" Margin="0,0,4,0" Padding="0"
                               Appearance="Transparent" ToolTip="Zoom out"
                               Click="OnZoomOutClick">
                        <TextBlock Text="−" FontSize="14" FontWeight="SemiBold"/>
                    </ui:Button>
                    <TextBlock x:Name="ZoomIndicator" Text="100%"
                               VerticalAlignment="Center"
                               FontSize="12"
                               MinWidth="44"
                               TextAlignment="Center"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    <ui:Button Width="32" Height="28" Margin="4,0,12,0" Padding="0"
                               Appearance="Transparent" ToolTip="Zoom in"
                               Click="OnZoomInClick">
                        <TextBlock Text="+" FontSize="14" FontWeight="SemiBold"/>
                    </ui:Button>
                    <ui:Button Content="Fit Window" Padding="10,2"
                               Appearance="Transparent"
                               Click="OnFitWindowClick"/>
                </StackPanel>
                <TextBlock/>
            </DockPanel>
        </Border>

        <Border DockPanel.Dock="Bottom"
                BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                Padding="16,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <ui:Button Content="Print..." Width="96" Margin="0,0,8,0"
                           Appearance="Primary" IsDefault="True"
                           Click="OnPrintClick"/>
                <ui:Button Content="Close" Width="96" IsCancel="True" Click="OnCloseClick"/>
            </StackPanel>
        </Border>

        <ListBox x:Name="PageList"
                 Background="#3A3A3A"
                 BorderThickness="0"
                 Padding="20"
                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 ScrollViewer.CanContentScroll="True"
                 VirtualizingPanel.IsVirtualizing="True"
                 VirtualizingPanel.VirtualizationMode="Recycling"
                 VirtualizingPanel.ScrollUnit="Pixel"
                 VirtualizingPanel.CacheLength="2,2"
                 VirtualizingPanel.CacheLengthUnit="Page"
                 KeyboardNavigation.DirectionalNavigation="None">
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <VirtualizingStackPanel Orientation="Vertical"/>
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Margin" Value="0,0,0,12"/>
                    <Setter Property="HorizontalAlignment" Value="Center"/>
                    <Setter Property="Focusable" Value="False"/>
                    <Setter Property="IsTabStop" Value="False"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <ContentPresenter/>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Background="White"
                            BorderBrush="#222"
                            BorderThickness="1"
                            SnapsToDevicePixels="True"
                            Width="{Binding DisplayWidth}"
                            Height="{Binding DisplayHeight}"
                            DataContextChanged="OnPageContainerDataContextChanged">
                        <Image Source="{Binding Image}" Stretch="Uniform" IsHitTestVisible="False"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>
</ui:FluentWindow>
